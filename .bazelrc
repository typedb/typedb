# Enable isolated extension usages for crate universe
common --experimental_isolated_extension_usages

# Fix macOS deployment target for Bzlmod mode (Bazel 8+)
# Without this, Bazel auto-detects the system macOS version (e.g., 26.x) and sets
# -mmacosx-version-min=26.x, which conflicts with RocksDB's -mmacosx-version-min=10.11
# causing C++17 aligned allocation errors. macOS 11.0 is compatible with both.
build --macos_minimum_os=11.0

try-import ./.bazel-remote-cache.rc

# Allow empty globs (many checkstyle_test patterns may not match)
common --noincompatible_disallow_empty_glob

# Fix Java runfiles path resolution in Bzlmod mode (required by release note validation)
build --legacy_external_runfiles

build --incompatible_strict_action_env --remote_download_toplevel --disk_cache=~/.cache/bazel --java_runtime_version=remotejdk_21
run --incompatible_strict_action_env
test --incompatible_strict_action_env --test_env=PATH

# CI configuration: disables disk cache to prevent cache size issues in CI environments
build:ci --disk_cache=

# Stress test configuration
test:stress --runs_per_test=50 --cache_test_results=no --jobs=1

# Windows: enable proper symlink support
startup --windows_enable_symlinks
startup --host_jvm_args=-Xmx2g
build --jobs=4
