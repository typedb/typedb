@@ -201,7 +201,14 @@ impl BuildScriptOutput {
     }

     fn redact_exec_root(value: &str, exec_root: &str) -> String {
-        value.replace(exec_root, "${pwd}")
+        let result = value.replace(exec_root, "${pwd}");
+        // Normalize path separators on Windows: build scripts may emit paths
+        // constructed by joining current_dir() (backslashes) with Bazel runfile
+        // paths (forward slashes), producing mixed-separator paths in -L flags
+        // and env vars that MSVC link.exe cannot resolve.
+        #[cfg(target_family = "windows")]
+        let result = result.replace('/', "\\");
+        result
     }

